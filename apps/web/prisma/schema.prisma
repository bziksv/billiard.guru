generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum TournamentFormat {
  OLYMPIC
  /** Олимпийская до 1 поражения + матч за 3–4 место */
  OLYMPIC_1L_BRONZE
  SWISS
  FIXED_SWISS
  /** 16→8 (27+1 встреч): эталон TS + матч за 3–4 (#28) */
  FIXED_SWISS_16_BRONZE
  /** 16→8 (28): копия 16_BRONZE, подпись 1/4 + доп.игра */
  FIXED_SWISS_16R4_1_3_mesto
  /** 16→8 (27): копия FIXED_SWISS, подпись 1/4, два 3-их */
  FIXED_SWISS_16R4_2_3_mesta
  /** 16→8 (24): олимпийка с 1/2 + матч за 3–4 (#28), без 1/4 */
  FIXED_SWISS_16R2_1_3_mesto
  /** 8→4 (13+1): oлимпийka с 1/4 + матч за 3–4 (#14) */
  FIXED_SWISS_8R4_1_3_mesto
  /** 32→16 (59/60): олимпийка с 1/4 */
  FIXED_SWISS_32
  /** 32→16 (60): 1/4 + матч за 3–4 */
  FIXED_SWISS_32_BRONZE
  /** 32→16 (59): копия R8, подпись 1/4 */
  FIXED_SWISS_32R4_2_3_mesta
  /** 32→16 (60): копия R8 bronze, подпись 1/4 */
  FIXED_SWISS_32R4_1_3_mesto
  /** 32→16 (59 встреч): олимпийка с 1/8 */
  FIXED_SWISS_32R8
  /** 32→16 (55): олимпийка с 1/8, вылет с 1/8 — места 9–12, без #49–#52 */
  FIXED_SWISS_32R8_2_3_mesta
  /** 32→16 (56): копия R8_2_3_mesta + матч за 3–4 (#60) */
  FIXED_SWISS_32R8_1_3_mesto
  /** 32→16 (60 встреч): 1/8 + матч за 3–4 (#60) */
  FIXED_SWISS_32R8_BRONZE
  /** 64→32 (111): R8 elim, два 3-их без доп.игры */
  FIXED_SWISS_64R8_2_3_mesta
  /** 64→32 (112): R8 elim + матч за 3–4 (#120) */
  FIXED_SWISS_64R8_1_3_mesto
  /** 128→64 (215): R8 elim, два 3-их без доп.игры */
  FIXED_SWISS_128R8_2_3_mesta
  /** 128→64 (216): R8 elim + матч за 3–4 */
  FIXED_SWISS_128R8_1_3_mesto
  /** 256→128 (492): R8 elim + матч за 3–4 (#492) */
  FIXED_SWISS_256R8_1_3_mesto
  /** 64→32 (111 встреч): эталонная сетка, олимпийка с 1/8 */
  FIXED_SWISS_64
  /** 64→32 (112 встреч): эталон + матч за 3–4 (#112 под финалом) */
  FIXED_SWISS_64_BRONZE
  PAIR_OLYMPIC
  PAIR_OLYMPIC_1L_BRONZE
  PAIR_SWISS
  FIXED_PAIR_SWISS
  FIXED_PAIR_SWISS_16_BRONZE
  FIXED_PAIR_SWISS_16R4_1_3_mesto
  FIXED_PAIR_SWISS_16R4_2_3_mesto
  FIXED_PAIR_SWISS_16R2_1_3_mesto
  FIXED_PAIR_SWISS_8R4_1_3_mesto
  FIXED_PAIR_SWISS_32
  FIXED_PAIR_SWISS_32_BRONZE
  FIXED_PAIR_SWISS_64
  FIXED_PAIR_SWISS_64_BRONZE
  /** 64→32 эталон из Excel 64-16 ×2gr.xls (тест с эксельки) */
  EXCEL_REF_64
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum RegistrationSource {
  CLUB
  SELF
}

enum TournamentStatus {
  DRAFT
  PENDING_CLUB_APPROVAL
  OPEN
  ACTIVE
  FINISHED
}

/// Какой рейтинг учитывать при лимите записи и рассылке.
enum TournamentRatingSource {
  /** Клубный рейтинг; если не задан — общий */
  CLUB
  /** Только общий рейтинг игрока */
  SYSTEM
}

enum MatchStatus {
  SCHEDULED
  FINISHED
  WALKOVER
}

enum UserRole {
  PLAYER
  SUPERADMIN
}

enum LoginChallengeStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum LoginChallengeMethod {
  TELEGRAM
  CALL
}

enum IdeaStatus {
  PENDING
  APPROVED
  REJECTED
  UNPUBLISHED
}

enum IdeaVoteValue {
  LIKE
  DISLIKE
}

/// Разовая игра или регулярные встречи («Покатать»).
enum PlayListingScheduleType {
  ONE_TIME
  RECURRING
}

enum PlayListingStatus {
  OPEN
  MATCHED
  CLOSED
}

/// Что ищет автор объявления.
enum PlayListingKind {
  SPARRING
  PARTNER
  OPPONENT
  TRAINING
  OTHER
}

enum PlayListingResponseStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

model Country {
  id     String @id @default(cuid())
  nameRu String @unique @map("name_ru")
  nameEn String? @map("name_en")
  cities City[]

  @@map("countries")
}

model City {
  id        String  @id @default(cuid())
  nameRu    String  @map("name_ru")
  nameEn    String? @map("name_en")
  countryId String  @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])
  latitude  Float?  @map("latitude")
  longitude Float?  @map("longitude")
  players      Player[]
  clubs        Club[]
  playListings PlayListing[]

  @@unique([countryId, nameRu])
  @@map("cities")
}

model Club {
  id               String   @id @default(cuid())
  name             String
  nameLatin        String?  @map("name_latin")
  cityId           String   @map("city_id")
  city             City     @relation(fields: [cityId], references: [id])
  phone            String
  displayPhone     String?  @map("display_phone")
  email            String?
  photoUrl         String?  @map("photo_url")
  galleryUrls      Json?    @map("gallery_urls")
  description      String?  @db.Text
  descriptionEn    String?  @map("description_en") @db.Text
  address          String?  @db.Text
  addressEn        String?  @map("address_en") @db.Text
  latitude         Float?   @map("latitude")
  longitude        Float?   @map("longitude")
  workingHours     String?  @map("working_hours") @db.Text
  workingHoursEn   String?  @map("working_hours_en") @db.Text
  weeklyHours      Json?    @map("weekly_hours")
  tableCount       Int?     @map("table_count")
  tableCounts      Json?    @map("table_counts")
  floorPlan          Json?    @map("floor_plan")
  gamePrice        String?  @map("game_price") @db.Text
  gamePriceEn      String?  @map("game_price_en") @db.Text
  priceTiers       Json?    @map("price_tiers")
  priceTiersEn     Json?    @map("price_tiers_en")
  bookingEnabled   Boolean  @default(true) @map("booking_enabled")
  bookingSlotMinutes Int    @default(60) @map("booking_slot_minutes")
  bookingAdvanceDays Int    @default(14) @map("booking_advance_days")
  telegramId       String?  @map("telegram_id")
  telegramUsername String?  @map("telegram_username")
  isVerified       Boolean  @default(false) @map("is_verified")
  confirmToken     String?  @unique @map("confirm_token")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tournaments    Tournament[]
  registrations  TournamentRegistration[]
  teams          TournamentTeam[]
  playerRatings  ClubPlayerRating[]
  news           ClubNews[]
  tableBookings  TableBooking[]
  ideas          Idea[]
  playListings   PlayListing[]
  staff          ClubStaff[]

  @@index([phone])
  @@index([telegramId])
  @@map("clubs")
}

/// Сотрудник клуба: доступ к /manage как у владельца (по приглашению владельца).
model ClubStaff {
  id        String   @id @default(cuid())
  clubId    String   @map("club_id")
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId  String   @map("player_id")
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([clubId, playerId])
  @@index([playerId])
  @@map("club_staff")
}

enum TableBookingKind {
  PLAYER
  CLUB
  BLOCK
}

model TableBooking {
  id          String             @id @default(cuid())
  clubId      String             @map("club_id")
  club        Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId    String?            @map("player_id")
  player      Player?            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  kind        TableBookingKind   @default(PLAYER)
  tableFormat String             @map("table_format")
  floorItemId String?            @map("floor_item_id")
  startsAt    DateTime           @map("starts_at")
  endsAt      DateTime           @map("ends_at")
  status      RegistrationStatus @default(PENDING)
  playerNote  String?            @map("player_note") @db.Text
  clubNote    String?            @map("club_note") @db.Text
  guestName   String?            @map("guest_name")
  guestPhone  String?            @map("guest_phone")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@index([clubId, startsAt])
  @@index([playerId, startsAt])
  @@map("table_bookings")
}

model ClubNews {
  id              String     @id @default(cuid())
  clubId          String     @map("club_id")
  club            Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  authorId        String?    @map("author_id")
  author          Player?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  title           String
  body            String     @db.Text
  titleEn         String?    @map("title_en")
  bodyEn          String?    @map("body_en") @db.Text
  status          IdeaStatus @default(APPROVED)
  moderationToken String?    @unique @map("moderation_token")
  moderatedAt     DateTime?  @map("moderated_at")
  moderatedById   String?    @map("moderated_by_id")
  rejectReason    String?    @map("reject_reason") @db.Text
  publishedAt     DateTime?  @map("published_at")
  /** Запрос рассылки в мессенджеры игрокам города (платная опция, см. docs/MONETIZATION.md). */
  cityBroadcastRequested Boolean @default(false) @map("city_broadcast_requested")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([clubId, publishedAt])
  @@index([status, createdAt])
  @@map("club_news")
}

/** Новости платформы billiard.guru (не привязаны к клубу). */
model SiteNews {
  id          String     @id @default(cuid())
  title       String
  body        String     @db.Text
  titleEn     String?    @map("title_en")
  bodyEn      String?    @map("body_en") @db.Text
  status      IdeaStatus @default(APPROVED)
  authorId    String?    @map("author_id")
  author      Player?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  publishedAt DateTime?  @map("published_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([status, publishedAt])
  @@map("site_news")
}

model Player {
  id               String   @id @default(cuid())
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  middleName       String?  @map("middle_name")
  firstNameLatin   String?  @map("first_name_latin")
  lastNameLatin    String?  @map("last_name_latin")
  middleNameLatin  String?  @map("middle_name_latin")
  cityId           String   @map("city_id")
  city             City     @relation(fields: [cityId], references: [id])
  phone            String   @unique
  email            String?
  birthDate        DateTime? @map("birth_date") @db.Date
  photoUrl         String?  @map("photo_url")
  telegramId       String?  @unique @map("telegram_id")
  telegramUsername String?  @map("telegram_username")
  rating           Float    @default(0)
  about            String?  @db.Text
  aboutEn          String?  @map("about_en") @db.Text
  isCoach          Boolean  @default(false) @map("is_coach")
  coachBio         String?  @map("coach_bio") @db.Text
  coachBioEn       String?  @map("coach_bio_en") @db.Text
  coachGalleryUrls Json?    @map("coach_gallery_urls")
  coachReviewAvg   Float?   @map("coach_review_avg")
  coachReviewCount Int      @default(0) @map("coach_review_count")
  role             UserRole @default(PLAYER)
  isVerified       Boolean  @default(false) @map("is_verified")
  confirmToken     String?  @unique @map("confirm_token")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  registrations TournamentRegistration[]
  ratingHistory RatingChange[]
  clubRatings   ClubPlayerRating[]
  teamsAsPlayer1 TournamentTeam[] @relation("TeamPlayer1")
  teamsAsPlayer2 TournamentTeam[] @relation("TeamPlayer2")
  loginChallenges LoginChallenge[]
  ideas                Idea[]
  ideaVotes            IdeaVote[]
  clubNewsAuthored     ClubNews[]
  siteNewsAuthored     SiteNews[]
  playListings         PlayListing[]
  playListingResponses PlayListingResponse[]
  tableBookings        TableBooking[]
  clubStaff            ClubStaff[]
  coachReviewsReceived CoachRating[] @relation("CoachReviewsReceived")
  coachReviewsGiven    CoachRating[] @relation("CoachReviewsGiven")
  notificationPreferences PlayerNotificationPreference[]
  pageViews              SitePageView[]

  @@map("players")
}

enum AnalyticsSurface {
  MARKETING
  ADMIN
  MANAGE
}

/// Просмотры страниц (собственная аналитика посещений).
model SitePageView {
  id        String           @id @default(cuid())
  visitorId String           @map("visitor_id") @db.VarChar(36)
  playerId  String?          @map("player_id")
  player    Player?          @relation(fields: [playerId], references: [id], onDelete: SetNull)
  surface   AnalyticsSurface
  path      String           @db.VarChar(512)
  referrer  String?          @db.VarChar(512)
  countryCode String?        @map("country_code") @db.VarChar(2)
  countryName String?        @map("country_name") @db.VarChar(64)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([surface, createdAt])
  @@index([visitorId, createdAt])
  @@index([playerId, createdAt])
  @@index([path, createdAt])
  @@index([countryCode, createdAt])
  @@index([createdAt])
  @@map("site_page_views")
}

/// Подписка игрока на типы Telegram-уведомлений (нет строки = включено).
model PlayerNotificationPreference {
  playerId       String   @map("player_id")
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  notificationId String   @map("notification_id")
  enabled        Boolean  @default(true)
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@id([playerId, notificationId])
  @@map("player_notification_preferences")
}

/// Оценка игрока тренера (1–5), не путать с турнирным рейтингом Player.rating.
model CoachRating {
  id        String   @id @default(cuid())
  coachId   String   @map("coach_id")
  coach     Player   @relation("CoachReviewsReceived", fields: [coachId], references: [id], onDelete: Cascade)
  raterId   String   @map("rater_id")
  rater     Player   @relation("CoachReviewsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  score     Int
  comment   String?  @db.Text
  commentEn String?  @map("comment_en") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([coachId, raterId])
  @@index([coachId, createdAt])
  @@map("coach_ratings")
}

model ClubPlayerRating {
  id        String   @id @default(cuid())
  clubId    String   @map("club_id")
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId  String   @map("player_id")
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  rating    Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clubId, playerId])
  @@map("club_player_ratings")
}

model LoginChallenge {
  id          String               @id @default(cuid())
  token       String               @unique
  playerId    String               @map("player_id")
  player      Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  method      LoginChallengeMethod @default(TELEGRAM)
  status      LoginChallengeStatus @default(PENDING)
  expiresAt   DateTime             @map("expires_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  confirmedAt DateTime?            @map("confirmed_at")

  @@index([status, method, expiresAt])
  @@map("login_challenges")
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  nameEn      String?          @map("name_en")
  description String?          @db.Text
  descriptionEn String?          @map("description_en") @db.Text
  clubId      String           @map("club_id")
  club        Club             @relation(fields: [clubId], references: [id])
  format              TournamentFormat
  /// Дисциплина (тип стола): PYRAMID/POOL/SNOOKER/CHINESE_POOL/CAROM
  discipline          String?          @map("discipline")
  /// Подвид дисциплины (тип игры), напр. MOSCOW/P8/THREE_CUSHION
  gameType            String?          @map("game_type")
  /// Парный режим поверх обычной сетки: регистрация по одному игроку (лимит ×2), пары собирает организатор
  isPair              Boolean          @default(false) @map("is_pair")
  status              TournamentStatus @default(DRAFT)
  /// Макс. рейтинг для записи и рассылки (null — без лимита)
  ratingMax           Float?                   @map("rating_max")
  /// Источник рейтинга для лимита (по умолчанию — клубный)
  ratingSource        TournamentRatingSource   @default(CLUB) @map("rating_source")
  /// Фора по шагу рейтинга 0,5 (false — только целая часть разницы, без +1 в нечётных)
  handicapHalfStep    Boolean          @default(true) @map("handicap_half_step")
  /// Не слать Telegram по этому турниру (тестовые копии и отладка)
  suppressNotifications Boolean        @default(false) @map("suppress_notifications")
  /// ID столов схемы зала или virtual:FORMAT:n — под турнир
  tableIds            Json?            @map("table_ids")
  /// Ссылки на трансляции по id стола { "floor-id": "https://..." }
  tableStreams        Json?            @map("table_streams")
  startsAt            DateTime?        @map("starts_at")
  clubApprovalToken   String?          @unique @map("club_approval_token")
  publishedAt         DateTime?        @map("published_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  registrations TournamentRegistration[]
  teams         TournamentTeam[]
  matches       TournamentMatch[]

  @@map("tournaments")
}

model TournamentTeam {
  id           String             @id @default(cuid())
  tournamentId String             @map("tournament_id")
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String?
  player1Id    String             @map("player1_id")
  player1      Player             @relation("TeamPlayer1", fields: [player1Id], references: [id])
  player2Id    String?            @map("player2_id")
  player2      Player?            @relation("TeamPlayer2", fields: [player2Id], references: [id])
  clubId       String?            @map("club_id")
  club         Club?              @relation(fields: [clubId], references: [id])
  source       RegistrationSource
  status       RegistrationStatus @default(PENDING)
  feePaid      Boolean            @default(false) @map("fee_paid")
  /// Переопределённый рейтинг пары для посева (если null — берётся сумма рейтингов игроков). Для сыгранных пар.
  ratingOverride Float?           @map("rating_override")
  seed         Int?
  swissPoints  Int                @default(0) @map("swiss_points")
  createdAt    DateTime           @default(now()) @map("created_at")
  confirmedAt  DateTime?          @map("confirmed_at")

  matchesAsTeam1 TournamentMatch[] @relation("MatchTeam1")
  matchesAsTeam2 TournamentMatch[] @relation("MatchTeam2")
  matchesWon     TournamentMatch[] @relation("MatchWinner")

  @@unique([tournamentId, player1Id])
  @@map("tournament_teams")
}

model TournamentMatch {
  id           String          @id @default(cuid())
  tournamentId String          @map("tournament_id")
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int
  slot         Int
  team1Id      String?         @map("team1_id")
  team1        TournamentTeam? @relation("MatchTeam1", fields: [team1Id], references: [id])
  team2Id      String?         @map("team2_id")
  team2        TournamentTeam? @relation("MatchTeam2", fields: [team2Id], references: [id])
  winnerTeamId String?         @map("winner_team_id")
  winnerTeam   TournamentTeam? @relation("MatchWinner", fields: [winnerTeamId], references: [id])
  team1Score   Int?            @map("team1_score")
  team2Score   Int?            @map("team2_score")
  startedAt    DateTime?       @map("started_at")
  finishedAt   DateTime?       @map("finished_at")
  /// Стол турнира (id с плана зала или virtual:FORMAT:n)
  tableId      String?         @map("table_id")
  status       MatchStatus     @default(SCHEDULED)
  createdAt    DateTime        @default(now()) @map("created_at")

  @@unique([tournamentId, round, slot])
  @@map("tournament_matches")
}

model TournamentRegistration {
  id           String             @id @default(cuid())
  tournamentId String             @map("tournament_id")
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerId     String             @map("player_id")
  player       Player             @relation(fields: [playerId], references: [id])
  clubId       String?            @map("club_id")
  club         Club?              @relation(fields: [clubId], references: [id])
  source       RegistrationSource
  status       RegistrationStatus @default(PENDING)
  feePaid      Boolean            @default(false) @map("fee_paid")
  createdAt    DateTime           @default(now()) @map("created_at")
  confirmedAt  DateTime?          @map("confirmed_at")

  @@unique([tournamentId, playerId])
  @@map("tournament_registrations")
}

model RatingChange {
  id        String   @id @default(cuid())
  playerId  String   @map("player_id")
  player    Player   @relation(fields: [playerId], references: [id])
  oldRating Float    @map("old_rating")
  newRating Float    @map("new_rating")
  delta     Float
  reason    String
  matchId   String?  @map("match_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("rating_changes")
}

model AuditLog {
  id         String   @id @default(cuid())
  appVersion String   @map("app_version")
  actorType  String   @map("actor_type")
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  section    String?  @map("section")
  clubId     String?  @map("club_id")
  summary    String?  @db.Text @map("summary")
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([clubId, section, createdAt])
  @@index([section, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model Idea {
  id              String     @id @default(cuid())
  authorId        String     @map("author_id")
  author          Player     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  clubId          String?    @map("club_id")
  club            Club?      @relation(fields: [clubId], references: [id], onDelete: SetNull)
  title           String
  body            String     @db.Text
  titleEn         String?    @map("title_en")
  bodyEn          String?    @map("body_en")
  status          IdeaStatus @default(PENDING)
  moderationToken String?    @unique @map("moderation_token")
  likesCount      Int        @default(0) @map("likes_count")
  dislikesCount   Int        @default(0) @map("dislikes_count")
  moderatedAt     DateTime?  @map("moderated_at")
  moderatedById   String?    @map("moderated_by_id")
  rejectReason    String?    @map("reject_reason") @db.Text
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  votes IdeaVote[]

  @@map("ideas")
}

model IdeaVote {
  id        String        @id @default(cuid())
  ideaId    String        @map("idea_id")
  idea      Idea          @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  playerId  String        @map("player_id")
  player    Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  value     IdeaVoteValue
  createdAt DateTime      @default(now()) @map("created_at")

  @@unique([ideaId, playerId])
  @@map("idea_votes")
}

/// Объявление «Покатать» — игрок ищет партнёра/соперника для игры.
model PlayListing {
  id           String                  @id @default(cuid())
  authorId     String                  @map("author_id")
  author       Player                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  cityId       String                  @map("city_id")
  city         City                    @relation(fields: [cityId], references: [id])
  clubId       String?                 @map("club_id")
  club         Club?                   @relation(fields: [clubId], references: [id], onDelete: SetNull)
  title        String
  body         String?                 @db.Text
  titleEn      String?                 @map("title_en")
  bodyEn       String?                 @map("body_en") @db.Text
  kind         PlayListingKind         @default(SPARRING)
  scheduleType PlayListingScheduleType @map("schedule_type")
  /// Для разовой игры — дата и время начала.
  playAt       DateTime?               @map("play_at")
  /// Для регулярных встреч — дни недели 0=вс … 6=сб (JSON-массив чисел).
  weekdays     Json?
  timeFrom     String?                 @map("time_from")
  timeTo       String?                 @map("time_to")
  gameFormat   String?                 @map("game_format")
  ratingMin    Float?                  @map("rating_min")
  ratingMax    Float?                  @map("rating_max")
  /// «1», «1-4», «пара на пару» и т.п.
  playersNeeded String                 @default("1") @map("players_needed") @db.VarChar(48)
  /// Опубликовано клубом через кабинет управления (не личное объявление игрока).
  publishedByClub Boolean              @default(false) @map("published_by_club")
  status       PlayListingStatus       @default(OPEN)
  expiresAt    DateTime?               @map("expires_at")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  responses PlayListingResponse[]

  @@index([cityId, status, createdAt])
  @@index([authorId, createdAt])
  @@index([status, expiresAt])
  @@map("play_listings")
}

/// Отклик на объявление «Покатать».
model PlayListingResponse {
  id        String                    @id @default(cuid())
  listingId String                    @map("listing_id")
  listing   PlayListing               @relation(fields: [listingId], references: [id], onDelete: Cascade)
  playerId  String                    @map("player_id")
  player    Player                    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  message   String?                   @db.Text
  messageEn String?                   @map("message_en") @db.Text
  status    PlayListingResponseStatus @default(PENDING)
  createdAt DateTime                  @default(now()) @map("created_at")
  updatedAt DateTime                  @updatedAt @map("updated_at")

  @@unique([listingId, playerId])
  @@index([playerId, createdAt])
  @@map("play_listing_responses")
}

/// Глобальные настройки Telegram-уведомлений (одна строка).
model NotificationGlobalConfig {
  id              String   @id @default("default")
  testModeEnabled Boolean  @default(false) @map("test_mode_enabled")
  /// JSON: string[] — id игроков для тестовой рассылки
  testPlayerIds   Json     @default("[]") @map("test_player_ids")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("notification_global_config")
}

/// Настройки по типу уведомления (id из NOTIFICATION_CATALOG).
model NotificationTypeConfig {
  notificationId   String   @id @map("notification_id")
  enabled            Boolean  @default(true)
  templateOverride   String?  @db.Text @map("template_override")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("notification_type_config")
}

/// Вкл/выкл типа сетки (код = TournamentFormat, реестр BRACKET_FORMAT_CATALOG).
model BracketFormatConfig {
  formatCode        String   @id @map("format_code")
  /// Переопределение подписи в списках (null — из каталога)
  adminLabel        String?  @map("admin_label") @db.VarChar(500)
  enabled           Boolean  @default(true)
  /// Техобслуживание: тип виден в админке, но недоступен при создании турнира
  maintenanceMode   Boolean  @default(false) @map("maintenance_mode")
  /// Скрыт из списка «Типы сеток» в админке (турниры с форматом остаются)
  hiddenInAdmin     Boolean  @default(false) @map("hidden_in_admin")
  /// Переопределение лимита участников (null — значение по умолчанию для формата)
  participantMin    Int?     @map("participant_min")
  participantMax    Int?     @map("participant_max")
  participantExact  Int?     @map("participant_exact")
  /// null — брать из BRACKET_FORMAT_CATALOG; иначе переопределение «эталон»
  isReference       Boolean? @map("is_reference")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("bracket_format_config")
}

/// Значения по умолчанию при создании турнира (одна строка, /admin/handicap).
model TournamentDefaultsConfig {
  id               String   @id @default("default")
  handicapHalfStep Boolean  @default(true) @map("handicap_half_step")
  limitByRating    Boolean                  @default(true) @map("limit_by_rating")
  ratingMax        Float?                   @map("rating_max")
  ratingSource     TournamentRatingSource   @default(CLUB) @map("rating_source")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  @@map("tournament_defaults_config")
}

/// Настройки автобэкапа БД (одна строка, /admin/db-backups).
model DbBackupConfig {
  id               String    @id @default("default")
  autoEnabled      Boolean   @default(false) @map("auto_enabled")
  /// Час (0–23) по времени сервера — только при autoIntervalHours = 0 (режим «раз в сутки»)
  autoHour         Int       @default(3) @map("auto_hour")
  autoMinute       Int       @default(0) @map("auto_minute")
  /// 0 = раз в сутки; иначе интервал в минутах (колонка auto_interval_hours — историческое имя)
  autoIntervalHours Int      @default(0) @map("auto_interval_hours")
  /// Сколько последних дампов хранить
  retainCount      Int       @default(14) @map("retain_count")
  lastAutoBackupAt DateTime? @map("last_auto_backup_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("db_backup_config")
}

/// Журнал отправок Telegram: каждая попытка (успех / ошибка / пропуск с причиной).
model TelegramDeliveryLog {
  id               String   @id @default(cuid())
  notificationId   String?  @map("notification_id")
  context          String
  status           String
  chatId           String?  @map("chat_id")
  playerId         String?  @map("player_id")
  entityType       String?  @map("entity_type")
  entityId         String?  @map("entity_id")
  batchId          String?  @map("batch_id")
  skipReason       String?  @map("skip_reason") @db.VarChar(512)
  errorMessage     String?  @map("error_message") @db.VarChar(512)
  messagePreview   String?  @map("message_preview") @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([notificationId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([batchId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("telegram_delivery_logs")
}
