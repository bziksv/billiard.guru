generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum TournamentFormat {
  OLYMPIC
  /** Олимпийская до 1 поражения + матч за 3–4 место */
  OLYMPIC_1L_BRONZE
  SWISS
  FIXED_SWISS
  /** 16→8 (27+1 встреч): эталон TS + матч за 3–4 (#28) */
  FIXED_SWISS_16_BRONZE
  /** 32→16 (59 встреч): эталон LLB, олимпийка с 1/8 */
  FIXED_SWISS_32
  /** 32→16 (60 встреч): эталон + матч за 3–4 (#60 под финалом) */
  FIXED_SWISS_32_BRONZE
  PAIR_OLYMPIC
  PAIR_OLYMPIC_1L_BRONZE
  PAIR_SWISS
  FIXED_PAIR_SWISS
  FIXED_PAIR_SWISS_16_BRONZE
  FIXED_PAIR_SWISS_32
  FIXED_PAIR_SWISS_32_BRONZE
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum RegistrationSource {
  CLUB
  SELF
}

enum TournamentStatus {
  DRAFT
  PENDING_CLUB_APPROVAL
  OPEN
  ACTIVE
  FINISHED
}

enum MatchStatus {
  SCHEDULED
  FINISHED
  WALKOVER
}

enum UserRole {
  PLAYER
  SUPERADMIN
}

enum LoginChallengeStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum IdeaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IdeaVoteValue {
  LIKE
  DISLIKE
}

/// Разовая игра или регулярные встречи («Покатать»).
enum PlayListingScheduleType {
  ONE_TIME
  RECURRING
}

enum PlayListingStatus {
  OPEN
  MATCHED
  CLOSED
}

/// Что ищет автор объявления.
enum PlayListingKind {
  SPARRING
  PARTNER
  OPPONENT
  TRAINING
  OTHER
}

enum PlayListingResponseStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

model Country {
  id     String @id @default(cuid())
  nameRu String @unique @map("name_ru")
  cities City[]

  @@map("countries")
}

model City {
  id        String  @id @default(cuid())
  nameRu    String  @map("name_ru")
  countryId String  @map("country_id")
  country   Country @relation(fields: [countryId], references: [id])
  latitude  Float?  @map("latitude")
  longitude Float?  @map("longitude")
  players      Player[]
  clubs        Club[]
  playListings PlayListing[]

  @@unique([countryId, nameRu])
  @@map("cities")
}

model Club {
  id               String   @id @default(cuid())
  name             String
  cityId           String   @map("city_id")
  city             City     @relation(fields: [cityId], references: [id])
  phone            String
  displayPhone     String?  @map("display_phone")
  email            String?
  photoUrl         String?  @map("photo_url")
  galleryUrls      Json?    @map("gallery_urls")
  description      String?  @db.Text
  address          String?  @db.Text
  latitude         Float?   @map("latitude")
  longitude        Float?   @map("longitude")
  workingHours     String?  @map("working_hours") @db.Text
  weeklyHours      Json?    @map("weekly_hours")
  tableCount       Int?     @map("table_count")
  tableCounts      Json?    @map("table_counts")
  floorPlan          Json?    @map("floor_plan")
  gamePrice        String?  @map("game_price") @db.Text
  priceTiers       Json?    @map("price_tiers")
  bookingEnabled   Boolean  @default(true) @map("booking_enabled")
  bookingSlotMinutes Int    @default(60) @map("booking_slot_minutes")
  bookingAdvanceDays Int    @default(14) @map("booking_advance_days")
  telegramId       String?  @map("telegram_id")
  telegramUsername String?  @map("telegram_username")
  isVerified       Boolean  @default(false) @map("is_verified")
  confirmToken     String?  @unique @map("confirm_token")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tournaments    Tournament[]
  registrations  TournamentRegistration[]
  teams          TournamentTeam[]
  playerRatings  ClubPlayerRating[]
  news           ClubNews[]
  tableBookings  TableBooking[]
  ideas          Idea[]
  playListings   PlayListing[]
  staff          ClubStaff[]

  @@index([phone])
  @@index([telegramId])
  @@map("clubs")
}

/// Сотрудник клуба: доступ к /manage как у владельца (по приглашению владельца).
model ClubStaff {
  id        String   @id @default(cuid())
  clubId    String   @map("club_id")
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId  String   @map("player_id")
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([clubId, playerId])
  @@index([playerId])
  @@map("club_staff")
}

enum TableBookingKind {
  PLAYER
  CLUB
  BLOCK
}

model TableBooking {
  id          String             @id @default(cuid())
  clubId      String             @map("club_id")
  club        Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId    String?            @map("player_id")
  player      Player?            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  kind        TableBookingKind   @default(PLAYER)
  tableFormat String             @map("table_format")
  floorItemId String?            @map("floor_item_id")
  startsAt    DateTime           @map("starts_at")
  endsAt      DateTime           @map("ends_at")
  status      RegistrationStatus @default(PENDING)
  playerNote  String?            @map("player_note") @db.Text
  clubNote    String?            @map("club_note") @db.Text
  guestName   String?            @map("guest_name")
  guestPhone  String?            @map("guest_phone")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@index([clubId, startsAt])
  @@index([playerId, startsAt])
  @@map("table_bookings")
}

model ClubNews {
  id          String   @id @default(cuid())
  clubId      String   @map("club_id")
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  title       String
  body        String   @db.Text
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([clubId, publishedAt])
  @@map("club_news")
}

model Player {
  id               String   @id @default(cuid())
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  middleName       String?  @map("middle_name")
  cityId           String   @map("city_id")
  city             City     @relation(fields: [cityId], references: [id])
  phone            String   @unique
  email            String?
  birthDate        DateTime? @map("birth_date") @db.Date
  photoUrl         String?  @map("photo_url")
  telegramId       String?  @unique @map("telegram_id")
  telegramUsername String?  @map("telegram_username")
  rating           Float    @default(0)
  about            String?  @db.Text
  isCoach          Boolean  @default(false) @map("is_coach")
  coachBio         String?  @map("coach_bio") @db.Text
  coachGalleryUrls Json?    @map("coach_gallery_urls")
  coachReviewAvg   Float?   @map("coach_review_avg")
  coachReviewCount Int      @default(0) @map("coach_review_count")
  role             UserRole @default(PLAYER)
  isVerified       Boolean  @default(false) @map("is_verified")
  confirmToken     String?  @unique @map("confirm_token")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  registrations TournamentRegistration[]
  ratingHistory RatingChange[]
  clubRatings   ClubPlayerRating[]
  teamsAsPlayer1 TournamentTeam[] @relation("TeamPlayer1")
  teamsAsPlayer2 TournamentTeam[] @relation("TeamPlayer2")
  loginChallenges LoginChallenge[]
  ideas                Idea[]
  ideaVotes            IdeaVote[]
  playListings         PlayListing[]
  playListingResponses PlayListingResponse[]
  tableBookings        TableBooking[]
  clubStaff            ClubStaff[]
  coachReviewsReceived CoachRating[] @relation("CoachReviewsReceived")
  coachReviewsGiven    CoachRating[] @relation("CoachReviewsGiven")
  notificationPreferences PlayerNotificationPreference[]

  @@map("players")
}

/// Подписка игрока на типы Telegram-уведомлений (нет строки = включено).
model PlayerNotificationPreference {
  playerId       String   @map("player_id")
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  notificationId String   @map("notification_id")
  enabled        Boolean  @default(true)
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@id([playerId, notificationId])
  @@map("player_notification_preferences")
}

/// Оценка игрока тренера (1–5), не путать с турнирным рейтингом Player.rating.
model CoachRating {
  id        String   @id @default(cuid())
  coachId   String   @map("coach_id")
  coach     Player   @relation("CoachReviewsReceived", fields: [coachId], references: [id], onDelete: Cascade)
  raterId   String   @map("rater_id")
  rater     Player   @relation("CoachReviewsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  score     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([coachId, raterId])
  @@index([coachId, createdAt])
  @@map("coach_ratings")
}

model ClubPlayerRating {
  id        String   @id @default(cuid())
  clubId    String   @map("club_id")
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId  String   @map("player_id")
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  rating    Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clubId, playerId])
  @@map("club_player_ratings")
}

model LoginChallenge {
  id          String               @id @default(cuid())
  token       String               @unique
  playerId    String               @map("player_id")
  player      Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  status      LoginChallengeStatus @default(PENDING)
  expiresAt   DateTime             @map("expires_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  confirmedAt DateTime?            @map("confirmed_at")

  @@map("login_challenges")
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  description String?          @db.Text
  clubId      String           @map("club_id")
  club        Club             @relation(fields: [clubId], references: [id])
  format              TournamentFormat
  status              TournamentStatus @default(DRAFT)
  startsAt            DateTime?        @map("starts_at")
  clubApprovalToken   String?          @unique @map("club_approval_token")
  publishedAt         DateTime?        @map("published_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  registrations TournamentRegistration[]
  teams         TournamentTeam[]
  matches       TournamentMatch[]

  @@map("tournaments")
}

model TournamentTeam {
  id           String             @id @default(cuid())
  tournamentId String             @map("tournament_id")
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String?
  player1Id    String             @map("player1_id")
  player1      Player             @relation("TeamPlayer1", fields: [player1Id], references: [id])
  player2Id    String?            @map("player2_id")
  player2      Player?            @relation("TeamPlayer2", fields: [player2Id], references: [id])
  clubId       String?            @map("club_id")
  club         Club?              @relation(fields: [clubId], references: [id])
  source       RegistrationSource
  status       RegistrationStatus @default(PENDING)
  seed         Int?
  swissPoints  Int                @default(0) @map("swiss_points")
  createdAt    DateTime           @default(now()) @map("created_at")
  confirmedAt  DateTime?          @map("confirmed_at")

  matchesAsTeam1 TournamentMatch[] @relation("MatchTeam1")
  matchesAsTeam2 TournamentMatch[] @relation("MatchTeam2")
  matchesWon     TournamentMatch[] @relation("MatchWinner")

  @@unique([tournamentId, player1Id])
  @@map("tournament_teams")
}

model TournamentMatch {
  id           String          @id @default(cuid())
  tournamentId String          @map("tournament_id")
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int
  slot         Int
  team1Id      String?         @map("team1_id")
  team1        TournamentTeam? @relation("MatchTeam1", fields: [team1Id], references: [id])
  team2Id      String?         @map("team2_id")
  team2        TournamentTeam? @relation("MatchTeam2", fields: [team2Id], references: [id])
  winnerTeamId String?         @map("winner_team_id")
  winnerTeam   TournamentTeam? @relation("MatchWinner", fields: [winnerTeamId], references: [id])
  team1Score   Int?            @map("team1_score")
  team2Score   Int?            @map("team2_score")
  startedAt    DateTime?       @map("started_at")
  finishedAt   DateTime?       @map("finished_at")
  status       MatchStatus     @default(SCHEDULED)
  createdAt    DateTime        @default(now()) @map("created_at")

  @@unique([tournamentId, round, slot])
  @@map("tournament_matches")
}

model TournamentRegistration {
  id           String             @id @default(cuid())
  tournamentId String             @map("tournament_id")
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerId     String             @map("player_id")
  player       Player             @relation(fields: [playerId], references: [id])
  clubId       String?            @map("club_id")
  club         Club?              @relation(fields: [clubId], references: [id])
  source       RegistrationSource
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime           @default(now()) @map("created_at")
  confirmedAt  DateTime?          @map("confirmed_at")

  @@unique([tournamentId, playerId])
  @@map("tournament_registrations")
}

model RatingChange {
  id        String   @id @default(cuid())
  playerId  String   @map("player_id")
  player    Player   @relation(fields: [playerId], references: [id])
  oldRating Float    @map("old_rating")
  newRating Float    @map("new_rating")
  delta     Float
  reason    String
  matchId   String?  @map("match_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("rating_changes")
}

model AuditLog {
  id         String   @id @default(cuid())
  appVersion String   @map("app_version")
  actorType  String   @map("actor_type")
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  section    String?  @map("section")
  clubId     String?  @map("club_id")
  summary    String?  @db.Text @map("summary")
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([clubId, section, createdAt])
  @@index([section, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model Idea {
  id              String     @id @default(cuid())
  authorId        String     @map("author_id")
  author          Player     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  clubId          String?    @map("club_id")
  club            Club?      @relation(fields: [clubId], references: [id], onDelete: SetNull)
  title           String
  body            String     @db.Text
  status          IdeaStatus @default(PENDING)
  moderationToken String?    @unique @map("moderation_token")
  likesCount      Int        @default(0) @map("likes_count")
  dislikesCount   Int        @default(0) @map("dislikes_count")
  moderatedAt     DateTime?  @map("moderated_at")
  moderatedById   String?    @map("moderated_by_id")
  rejectReason    String?    @map("reject_reason") @db.Text
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  votes IdeaVote[]

  @@map("ideas")
}

model IdeaVote {
  id        String        @id @default(cuid())
  ideaId    String        @map("idea_id")
  idea      Idea          @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  playerId  String        @map("player_id")
  player    Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  value     IdeaVoteValue
  createdAt DateTime      @default(now()) @map("created_at")

  @@unique([ideaId, playerId])
  @@map("idea_votes")
}

/// Объявление «Покатать» — игрок ищет партнёра/соперника для игры.
model PlayListing {
  id           String                  @id @default(cuid())
  authorId     String                  @map("author_id")
  author       Player                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  cityId       String                  @map("city_id")
  city         City                    @relation(fields: [cityId], references: [id])
  clubId       String?                 @map("club_id")
  club         Club?                   @relation(fields: [clubId], references: [id], onDelete: SetNull)
  title        String
  body         String?                 @db.Text
  kind         PlayListingKind         @default(SPARRING)
  scheduleType PlayListingScheduleType @map("schedule_type")
  /// Для разовой игры — дата и время начала.
  playAt       DateTime?               @map("play_at")
  /// Для регулярных встреч — дни недели 0=вс … 6=сб (JSON-массив чисел).
  weekdays     Json?
  timeFrom     String?                 @map("time_from")
  timeTo       String?                 @map("time_to")
  gameFormat   String?                 @map("game_format")
  ratingMin    Float?                  @map("rating_min")
  ratingMax    Float?                  @map("rating_max")
  playersNeeded Int                    @default(1) @map("players_needed")
  status       PlayListingStatus       @default(OPEN)
  expiresAt    DateTime?               @map("expires_at")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  responses PlayListingResponse[]

  @@index([cityId, status, createdAt])
  @@index([authorId, createdAt])
  @@index([status, expiresAt])
  @@map("play_listings")
}

/// Отклик на объявление «Покатать».
model PlayListingResponse {
  id        String                    @id @default(cuid())
  listingId String                    @map("listing_id")
  listing   PlayListing               @relation(fields: [listingId], references: [id], onDelete: Cascade)
  playerId  String                    @map("player_id")
  player    Player                    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  message   String?                   @db.Text
  status    PlayListingResponseStatus @default(PENDING)
  createdAt DateTime                  @default(now()) @map("created_at")
  updatedAt DateTime                  @updatedAt @map("updated_at")

  @@unique([listingId, playerId])
  @@index([playerId, createdAt])
  @@map("play_listing_responses")
}

/// Глобальные настройки Telegram-уведомлений (одна строка).
model NotificationGlobalConfig {
  id              String   @id @default("default")
  testModeEnabled Boolean  @default(false) @map("test_mode_enabled")
  /// JSON: string[] — id игроков для тестовой рассылки
  testPlayerIds   Json     @default("[]") @map("test_player_ids")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("notification_global_config")
}

/// Настройки по типу уведомления (id из NOTIFICATION_CATALOG).
model NotificationTypeConfig {
  notificationId   String   @id @map("notification_id")
  enabled            Boolean  @default(true)
  templateOverride   String?  @db.Text @map("template_override")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("notification_type_config")
}

/// Вкл/выкл типа сетки (код = TournamentFormat, реестр BRACKET_FORMAT_CATALOG).
model BracketFormatConfig {
  formatCode        String   @id @map("format_code")
  enabled           Boolean  @default(true)
  /// Техобслуживание: тип виден в админке, но недоступен при создании турнира
  maintenanceMode   Boolean  @default(false) @map("maintenance_mode")
  /// Скрыт из списка «Типы сеток» в админке (турниры с форматом остаются)
  hiddenInAdmin     Boolean  @default(false) @map("hidden_in_admin")
  /// Переопределение лимита участников (null — значение по умолчанию для формата)
  participantMin    Int?     @map("participant_min")
  participantMax    Int?     @map("participant_max")
  participantExact  Int?     @map("participant_exact")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("bracket_format_config")
}

/// Журнал отправок Telegram: каждая попытка (успех / ошибка / пропуск с причиной).
model TelegramDeliveryLog {
  id               String   @id @default(cuid())
  notificationId   String?  @map("notification_id")
  context          String
  status           String
  chatId           String?  @map("chat_id")
  playerId         String?  @map("player_id")
  entityType       String?  @map("entity_type")
  entityId         String?  @map("entity_id")
  batchId          String?  @map("batch_id")
  skipReason       String?  @map("skip_reason") @db.VarChar(512)
  errorMessage     String?  @map("error_message") @db.VarChar(512)
  messagePreview   String?  @map("message_preview") @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([notificationId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([batchId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("telegram_delivery_logs")
}
