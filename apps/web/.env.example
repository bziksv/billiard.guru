PORT=3010
NODE_ENV=development

# Docker: mysql://setka:setka@localhost:3306/setka
# Homebrew MySQL (root без пароля): mysql://root@localhost:3306/setka
#
# Beget — имя БД = имя пользователя (bziksv_bil). Спецсимволы в пароле URL-encode:
#   & → %26   * → %2A
#
# На сервере Beget (Passenger не видит localhost MySQL — используйте внешний хост):
# DATABASE_URL=mysql://bziksv_bil:PASSWORD@bziksv.beget.tech:3306/bziksv_bil
#
# С Mac / внешнее подключение (нужно включить в панели Beget → MySQL):
#   DATABASE_URL=mysql://bziksv_bil:PASSWORD@bziksv.beget.tech:3306/bziksv_bil
#
DATABASE_URL=mysql://setka:setka@localhost:3306/setka

APP_URL=http://localhost:3010
NEXT_PUBLIC_APP_URL=http://localhost:3010

LOG_LEVEL=debug
APP_VERSION=0.1.0

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=BilliardGuruBot
TELEGRAM_WEBHOOK_SECRET=
# Куда Telegram шлёт нажатия кнопок (всегда прод, даже при локальной разработке):
TELEGRAM_WEBHOOK_URL=https://billiard.guru/api/telegram/webhook

SESSION_SECRET=change-me-to-a-long-random-string

# Бэкапы БД (/admin/db-backups). Каталог по умолчанию: <repo>/data/db-backups
# DB_BACKUP_DIR=/home/b/bziksv/billiard.guru/setka/data/db-backups
# На Mac с MySQL 9 (Homebrew) mysqldump не работает с mysql_native_password — бэкап идёт через Node.js.
# Опционально: brew install mariadb && DB_BACKUP_MYSQLDUMP=/opt/homebrew/opt/mariadb/bin/mariadb-dump
# DB_BACKUP_MYSQLDUMP=/path/to/mysqldump
# DB_BACKUP_MYSQL=/path/to/mysql
# Корень репозитория на сервере (если автоопределение ошиблось): SETKA_REPO_ROOT=/home/b/bziksv/billiard.guru/setka
# DB_BACKUP_CRON_SECRET=long-random-string
# Секрет для cron (scripts/db-backup-cron.sh или db-backup-cron.php на Beget)
# DB_BACKUP_CRON_SECRET=long-random-string

# Production:
# APP_URL=https://billiard.guru
# NEXT_PUBLIC_APP_URL=https://billiard.guru
