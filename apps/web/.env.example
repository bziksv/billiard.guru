PORT=3010
NODE_ENV=development

# Одна БД для dev и prod (Beget). С Mac — внешний хост (в панели Beget → MySQL):
# DATABASE_URL=mysql://bziksv_bil:PASSWORD@bziksv.beget.tech:3306/bziksv_bil
#
# Beget — имя БД = имя пользователя (bziksv_bil). Спецсимволы в пароле URL-encode:
#   & → %26   * → %2A
#
# На сервере (Passenger): тот же DATABASE_URL с localhost или beget.tech — см. docs/DEPLOY.md
#
# Локальный Docker/Homebrew MySQL — только если сознательно отделяете данные (не наш дефолт):
# DATABASE_URL=mysql://setka:setka@localhost:3306/setka
#
DATABASE_URL=mysql://bziksv_bil:PASSWORD@bziksv.beget.tech:3306/bziksv_bil

APP_URL=http://localhost:3010
NEXT_PUBLIC_APP_URL=http://localhost:3010

LOG_LEVEL=debug
APP_VERSION=0.1.0

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=BilliardGuruBot
TELEGRAM_WEBHOOK_SECRET=
# Куда Telegram шлёт нажатия кнопок (всегда прод, даже при локальной разработке):
TELEGRAM_WEBHOOK_URL=https://billiard.guru/api/telegram/webhook

SESSION_SECRET=change-me-to-a-long-random-string

# Бэкапы БД (/admin/db-backups). Каталог по умолчанию: <repo>/data/db-backups
# DB_BACKUP_DIR=/home/b/bziksv/billiard.guru/setka/data/db-backups
# Фото клубов/игроков (prod, beget-setup создаёт ~/billiard.guru/shared/uploads):
# UPLOADS_DIR=/home/b/bziksv/billiard.guru/shared/uploads
# На Mac с MySQL 9 (Homebrew) mysqldump не работает с mysql_native_password — бэкап идёт через Node.js.
# Опционально: brew install mariadb && DB_BACKUP_MYSQLDUMP=/opt/homebrew/opt/mariadb/bin/mariadb-dump
# DB_BACKUP_MYSQLDUMP=/path/to/mysqldump
# DB_BACKUP_MYSQL=/path/to/mysql
# Корень git-репозитория на Beget (обязательно при atomic releases / ~/billiard.guru/current):
# SETKA_REPO_ROOT=/home/b/bziksv/billiard.guru/setka
# DB_BACKUP_CRON_SECRET=long-random-string

# Novofon — вход звонком (дополнительно к Telegram)
# NOVOFON_API_KEY=appid_...
# NOVOFON_API_SECRET=...
# E.164 без «+», например 79952224714
# NOVOFON_VERIFY_NUMBER=79952224714
# Пока номер не активирован в Novofon — false
# NOVOFON_CALL_AUTH_ENABLED=false
# Секрет в URL webhook: https://billiard.guru/api/novofon/webhook?secret=...
# NOVOFON_WEBHOOK_SECRET=long-random-string
# NOVOFON_WEBHOOK_IPS=37.139.38.215

# APP_URL=https://billiard.guru
# NEXT_PUBLIC_APP_URL=https://billiard.guru
